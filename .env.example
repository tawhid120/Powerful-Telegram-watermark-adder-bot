# ==== Telegram API credentials ====
# Get these from https://my.telegram.org
API_ID=1234567
API_HASH=your_api_hash_here

# Get this from @BotFather on Telegram
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Username of your bot without @, e.g. mywatermarkbot
BOT_USERNAME=mywatermarkbot

# ==== Mini App / WebApp ====
# Public HTTPS URL where the webapp (FastAPI) is served.
# Telegram Mini Apps REQUIRE a valid HTTPS domain (use ngrok/caddy/nginx+letsencrypt in production).
WEBAPP_URL=https://your-domain.com

# Host/port the local FastAPI server binds to
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# ==== Database ====
DATABASE_URL=sqlite+aiosqlite:///./storage/wmarkbot.db

# ==== Limits ====
FREE_PLAN_TEMPLATE_LIMIT=3
FREE_PLAN_CHANNEL_LIMIT=1
FREE_PLAN_DAILY_MB=200

NORMAL_PLAN_TEMPLATE_LIMIT=15
NORMAL_PLAN_CHANNEL_LIMIT=15
NORMAL_PLAN_DAILY_MB=3072

PRO_PLAN_TEMPLATE_LIMIT=100
PRO_PLAN_CHANNEL_LIMIT=100
PRO_PLAN_DAILY_MB=20480

# Max upload size accepted by the webapp (MB)
MAX_UPLOAD_MB=50

# Admin telegram user ids (comma separated) - get broadcast/stats access
ADMIN_IDS=

# Secret used to sign webapp auth tokens issued after Telegram initData validation
JWT_SECRET=change_this_to_a_long_random_string
